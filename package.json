{
  "name": "deep-slop",
  "version": "0.1.0",
  "description": "Deep AI slop detection with AST analysis, alternative import paths, dead code flow, type safety, and 12 engines. Far beyond aislop.",
  "type": "module",
  "bin": {
    "deep-slop": "./dist/cli.js",
    "deep-slop-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "rm -rf dist && NODE_ENV=production tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "scan": "pnpm build && node dist/cli.js scan .",
    "scan:json": "pnpm build && node dist/cli.js scan . --json"
  },
  "keywords": [
    "deep-slop",
    "ai-slop",
    "code-quality",
    "ast",
    "tree-sitter",
    "import-intelligence",
    "dead-code",
    "type-safety",
    "linter",
    "static-analysis"
  ],
  "author": "Romanchello",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Romanchello/deep-slop.git"
  },
  "homepage": "https://github.com/Romanchello/deep-slop#readme",
  "bugs": {
    "url": "https://github.com/Romanchello/deep-slop/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "graphology": "^0.25.4",
    "js-yaml": "^4.2.0",
    "micromatch": "^4.0.8",
    "minimatch": "^10.2.5",
    "picocolors": "^1.1.1",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.25.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.10",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.6.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
