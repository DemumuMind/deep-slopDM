{
  "name": "deep-slop",
  "version": "2.3.0",
  "description": "Deep AI slop detection with 25 AST-powered engines, 211+ rules, density-aware scoring, SARIF 2.1.0 output, MCP server, and auto-fix pipeline.",
  "type": "module",
  "bin": {
    "deep-slop": "./dist/deep-slop-bundled.js",
    "deep-slop-mcp": "./dist/mcp.js",
    "deep-slop-lsp": "./dist/lsp.js"
  },
  "files": [
    "dist/deep-slop-bundled.js",
    "dist/mcp.js",
    "dist/index.js",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "scripts",
    ".deep-slop/.deep-slop-ignore",
    "!dist/**/*.test.*",
    "!dist/**/*.test.js.map"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "rm -rf dist && NODE_ENV=production tsdown && node build-esbuild.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "scan": "pnpm build && node dist/deep-slop-bundled.js scan .",
    "scan:json": "pnpm build && node dist/deep-slop-bundled.js scan . --json"
  },
  "keywords": [
    "deep-slop",
    "ai-slop",
    "code-quality",
    "ast",
    "tree-sitter",
    "import-intelligence",
    "dead-code",
    "type-safety",
    "linter",
    "static-analysis"
  ],
  "author": "Romanchello",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DemumuMind/deep-slopDM.git"
  },
  "homepage": "https://github.com/DemumuMind/deep-slopDM#readme",
  "bugs": {
    "url": "https://github.com/DemumuMind/deep-slopDM/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "graphology": "^0.25.4",
    "js-yaml": "^4.2.0",
    "micromatch": "^4.0.8",
    "minimatch": "^10.2.5",
    "picocolors": "^1.1.1",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "vscode-languageserver": "^10.0.0",
    "web-tree-sitter": "^0.25.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.10",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "4.1.8",
    "esbuild": "^0.28.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "tree-sitter-javascript",
      "tree-sitter-python",
      "tree-sitter-typescript"
    ]
  }
}